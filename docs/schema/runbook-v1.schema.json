{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://failwarden.local/schema/runbook-v1.schema.json",
  "title": "FailWarden Runbook V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "description", "vars", "entry_step", "steps"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "vars": {
      "type": "object",
      "additionalProperties": true
    },
    "entry_step": {
      "type": "string",
      "minLength": 1
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/ssh_step"
          },
          {
            "$ref": "#/$defs/escalate_step"
          }
        ]
      }
    }
  },
  "$defs": {
    "expect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exit_code"],
      "properties": {
        "exit_code": {
          "type": "integer"
        },
        "stdout_contains": {
          "type": "string"
        },
        "stderr_contains": {
          "type": "string"
        }
      }
    },
    "ssh_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "name",
        "command",
        "expect",
        "timeout",
        "retries",
        "retry_delay",
        "on_success",
        "on_failure"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "const": "ssh"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "expect": {
          "$ref": "#/$defs/expect"
        },
        "timeout": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3600
        },
        "retries": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "retry_delay": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3600
        },
        "on_success": {
          "type": "string",
          "minLength": 1
        },
        "on_failure": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "notify": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slack_enabled", "email_enabled"],
      "properties": {
        "slack_enabled": {
          "type": "boolean"
        },
        "email_enabled": {
          "type": "boolean"
        },
        "slack_channel": {
          "type": "string"
        },
        "email_to": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "title": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    },
    "escalate_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "name", "notify"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "const": "escalate"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "notify": {
          "$ref": "#/$defs/notify"
        }
      }
    }
  }
}
