# Copy to .env.local and load with:
#   set -a
#   source .env.local
#   set +a
#
# This file is a local-only operator workflow example. Keep the real .env.local
# ignored and never commit real secrets.

FWO_DB_PATH=.data/fwo.sqlite3
FWO_AUDIT_DIR=.audit

# Use a dedicated automation key outside the repo.
FWO_SSH_KEY_PATH=~/.ssh/failwarden_ed25519

# Optional local-only password env var for --ssh-password-env.
FWO_LINUX_SSH_PASSWORD=

# Optional notifier configuration.
FWO_SLACK_WEBHOOK_URL=
FWO_SLACK_CHANNEL=#ops-alerts

FWO_SMTP_HOST=
FWO_SMTP_PORT=587
FWO_SMTP_USERNAME=
FWO_SMTP_PASSWORD=
FWO_SMTP_FROM=failwarden@example.local
FWO_SMTP_USE_TLS=true
