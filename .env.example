# FailWarden Orchestrator example environment values.
# Real secrets must not be committed.

# Database
FWO_DB_PATH=.data/fwo.sqlite3

# Logging
FWO_LOG_LEVEL=INFO
FWO_AUDIT_DIR=.audit

# SSH defaults
FWO_SSH_CONNECT_TIMEOUT=10

# Slack notifier
FWO_SLACK_WEBHOOK_URL=

# Email notifier
FWO_SMTP_HOST=
FWO_SMTP_PORT=587
FWO_SMTP_USERNAME=
FWO_SMTP_PASSWORD=
FWO_SMTP_FROM=
FWO_SMTP_TO=
