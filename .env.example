# FailWarden Orchestrator example environment values.
# Real secrets must not be committed.
# Copy these into an ignored file such as .env.local before loading them.

# Database
FWO_DB_PATH=.data/fwo.sqlite3

# Logging
FWO_LOG_LEVEL=INFO
FWO_AUDIT_DIR=.audit

# SSH defaults
FWO_SSH_CONNECT_TIMEOUT=10
# Use a local-only env var name for --ssh-password-env when password auth is needed.
# Example: export FWO_LINUX_SSH_PASSWORD='...'

# Slack notifier
FWO_SLACK_WEBHOOK_URL=
FWO_SLACK_CHANNEL=

# Email notifier
FWO_SMTP_HOST=
FWO_SMTP_PORT=587
FWO_SMTP_USERNAME=
FWO_SMTP_PASSWORD=
FWO_SMTP_FROM=
FWO_SMTP_USE_TLS=true
